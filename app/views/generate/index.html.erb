<% content_for :title, "Generate — UISchemes" %>

<div class="flex gap-0 h-full">

  <%# ── Controls panel ──────────────────────────────────────────────────── %>
  <aside class="w-72 shrink-0 border-r border-[--color-border] bg-[--color-surface] p-5 overflow-y-auto flex flex-col gap-6">
    <div>
      <h2 class="text-sm font-semibold text-[--color-text-base] mb-0.5">Palette Generator</h2>
      <p class="text-xs text-[--color-text-muted]">Pick a base colour, mood, and harmony rule to generate a palette.</p>
    </div>

    <%= form_with url: generate_path, method: :get, data: { controller: "color-picker randomize" } do |f| %>

      <%# Base colour %>
      <div class="flex flex-col gap-2">
        <label class="text-xs font-medium text-[--color-text-muted] uppercase tracking-wider">Base Colour</label>
        <div class="flex items-center gap-2">
          <input
            type="color"
            value="<%= @base_hex || '#7c6af7' %>"
            data-color-picker-target="picker"
            data-randomize-target="picker"
            data-action="input->color-picker#pickerChanged"
            class="w-10 h-10 rounded-lg cursor-pointer border-0 bg-transparent p-0"
          >
          <input
            type="text"
            name="base_hex"
            value="<%= @base_hex || '#7c6af7' %>"
            placeholder="#7c6af7"
            maxlength="7"
            spellcheck="false"
            data-color-picker-target="hex"
            data-randomize-target="hex"
            data-action="input->color-picker#hexChanged"
            class="flex-1 px-3 py-2 rounded-lg border border-[--color-border] bg-[--color-canvas] text-sm font-mono text-[--color-text-base] placeholder:text-[--color-text-faint] focus:outline-none focus:ring-2 focus:ring-[--color-brand]"
          >
        </div>
      </div>

      <%# Mood %>
      <div class="flex flex-col gap-2">
        <label class="text-xs font-medium text-[--color-text-muted] uppercase tracking-wider">Mood</label>
        <select name="mood"
          data-randomize-target="mood"
          class="px-3 py-2 rounded-lg border border-[--color-border] bg-[--color-canvas] text-sm text-[--color-text-base] focus:outline-none focus:ring-2 focus:ring-[--color-brand] appearance-none cursor-pointer">
          <% GenerateController::MOODS.each do |mood| %>
            <option value="<%= mood %>" <%= 'selected' if @mood == mood || (@mood.nil? && mood == 'dark') %>><%= mood.capitalize %></option>
          <% end %>
        </select>
      </div>

      <%# Harmony %>
      <div class="flex flex-col gap-2">
        <label class="text-xs font-medium text-[--color-text-muted] uppercase tracking-wider">Harmony</label>
        <select name="harmony"
          data-randomize-target="harmony"
          class="px-3 py-2 rounded-lg border border-[--color-border] bg-[--color-canvas] text-sm text-[--color-text-base] focus:outline-none focus:ring-2 focus:ring-[--color-brand] appearance-none cursor-pointer">
          <% GenerateController::HARMONIES.each do |harmony| %>
            <option value="<%= harmony %>" <%= 'selected' if @harmony == harmony || (@harmony.nil? && harmony == 'monochromatic') %>><%= harmony.capitalize %></option>
          <% end %>
        </select>
      </div>

      <%# Variations %>
      <div class="flex flex-col gap-2">
        <label class="text-xs font-medium text-[--color-text-muted] uppercase tracking-wider">Variations</label>
        <select name="variations"
          data-randomize-target="variations"
          class="px-3 py-2 rounded-lg border border-[--color-border] bg-[--color-canvas] text-sm text-[--color-text-base] focus:outline-none focus:ring-2 focus:ring-[--color-brand] appearance-none cursor-pointer">
          <% (1..GenerateController::MAX_VARIATIONS).each do |n| %>
            <option value="<%= n %>" <%= 'selected' if (@variations || 1) == n %>><%= n %> <%= n == 1 ? 'variation' : 'variations' %></option>
          <% end %>
        </select>
      </div>

      <button type="submit"
        style="background-color: var(--color-brand);"
        class="w-full flex items-center justify-center gap-2 px-4 py-2.5 rounded-lg text-sm font-semibold text-white transition-opacity duration-150 hover:opacity-90">
        <i data-lucide="wand-2" class="w-4 h-4"></i>
        Generate Palette
      </button>

      <button type="button"
        data-action="click->randomize#randomize"
        class="w-full flex items-center justify-center gap-2 px-4 py-2.5 rounded-lg text-sm font-medium border border-[--color-border] text-[--color-text-muted] hover:text-[--color-text-base] hover:border-[--color-brand-muted] transition-colors duration-150">
        <i data-lucide="shuffle" class="w-4 h-4"></i>
        Random
      </button>

    <% end %>
  </aside>

  <%# ── Main content area ───────────────────────────────────────────────── %>
  <div class="flex-1 overflow-y-auto px-8 py-8">

    <% if @error %>
      <div class="mb-6 flex items-start gap-3 px-4 py-3 rounded-lg border border-red-800/50 bg-red-950/30 text-red-400 text-sm">
        <i data-lucide="alert-circle" class="w-4 h-4 mt-0.5 shrink-0"></i>
        <%= @error %>
      </div>
    <% end %>

    <% if @palettes %>

      <% @palettes.each_with_index do |palette, idx| %>
        <% is_multi = @palettes.size > 1 %>

        <div class="<%= is_multi ? 'mb-12 pb-10 border-b border-[--color-border] last:border-0 last:mb-0 last:pb-0' : 'mb-10' %>">

          <% if is_multi %>
            <div class="flex items-center gap-2 mb-5">
              <span class="text-xs font-semibold uppercase tracking-wider text-[--color-text-faint]">Variation <%= idx + 1 %></span>
              <div class="flex-1 h-px bg-[--color-border]"></div>
            </div>
          <% end %>

          <%# Swatch strip %>
          <div class="flex rounded-xl overflow-hidden mb-6 h-20 shadow-lg">
            <% palette.each do |role, hex| %>
              <div class="flex-1 h-full relative group" style="background-color: <%= hex %>;" title="<%= role %>: <%= hex %>">
                <div class="absolute inset-0 flex items-end justify-start px-2 pb-1.5 opacity-0 group-hover:opacity-100 transition-opacity duration-150">
                  <span class="text-[10px] font-mono font-semibold px-1.5 py-0.5 rounded bg-black/40 text-white"><%= hex %></span>
                </div>
              </div>
            <% end %>
          </div>

          <%# Role cards grid %>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3 mb-8">
            <% palette.each do |role, hex| %>
              <div data-controller="clipboard" data-clipboard-text-value="<%= hex %>"
                   data-action="click->clipboard#copy"
                   class="flex flex-col gap-2 p-3 rounded-xl border border-[--color-border] bg-[--color-surface] cursor-pointer hover:border-[--color-brand-muted] transition-colors duration-150 group">
                <div class="w-full h-10 rounded-lg ring-1 ring-black/20" style="background-color: <%= hex %>;"></div>
                <div>
                  <p class="text-[11px] font-medium text-[--color-text-muted] capitalize mb-0.5"><%= role %></p>
                  <p class="text-[11px] font-mono text-[--color-text-faint]"><%= hex %></p>
                </div>
                <p class="text-[10px] text-[--color-text-faint] opacity-0 group-hover:opacity-100 transition-opacity duration-150" data-clipboard-target="label">Copy</p>
              </div>
            <% end %>
          </div>

          <%# Export panel %>
          <% css_export      = ":root {\n" + palette.map { |r, h| "  --color-#{r}: #{h};" }.join("\n") + "\n}" %>
          <% tailwind_export = "module.exports = {\n  theme: {\n    extend: {\n      colors: {\n" + palette.map { |r, h| "        #{r}: '#{h}'," }.join("\n") + "\n      },\n    },\n  },\n}" %>
          <% js_export       = "export const palette = {\n" + palette.map { |r, h| "  #{r}: '#{h}'," }.join("\n") + "\n};" %>

          <div data-controller="tabs">
            <div class="flex items-center gap-1 mb-4 border-b border-[--color-border] pb-3">
              <span class="text-xs font-medium text-[--color-text-muted] mr-2 uppercase tracking-wider">Export as</span>
              <% [["css", "CSS Variables"], ["tailwind", "Tailwind Config"], ["js", "JavaScript"]].each_with_index do |(panel_id, label), i| %>
                <button
                  data-tabs-target="tab"
                  data-panel="<%= panel_id %>"
                  data-active="<%= i == 0 %>"
                  data-action="click->tabs#switch"
                  aria-selected="<%= i == 0 %>"
                  class="px-3 py-1.5 rounded-md text-xs font-medium transition-colors duration-150">
                  <%= label %>
                </button>
              <% end %>
            </div>

            <% [["css", css_export], ["tailwind", tailwind_export], ["js", js_export]].each_with_index do |(panel_id, content), i| %>
              <div data-tabs-target="panel" data-tab-id="<%= panel_id %>" <%= 'hidden' if i > 0 %>
                   data-controller="clipboard"
                   data-action="click->clipboard#copy"
                   class="relative group cursor-pointer">
                <button class="absolute top-3 right-3 flex items-center gap-1.5 px-2.5 py-1 rounded-md border border-[--color-border] bg-[--color-surface-raised] text-[10px] text-[--color-text-muted] opacity-0 group-hover:opacity-100 transition-opacity duration-150">
                  <i data-lucide="copy" class="w-3 h-3"></i>
                  <span data-clipboard-target="label">Copy</span>
                </button>
                <pre data-clipboard-target="source"
                     class="p-4 rounded-xl border border-[--color-border] bg-[--color-canvas] text-xs font-mono text-[--color-text-muted] overflow-x-auto leading-relaxed whitespace-pre"><code><%= content %></code></pre>
              </div>
            <% end %>
          </div>

        </div>
      <% end %>

    <% else %>
      <%# Empty state — no palette generated yet %>
      <div class="flex flex-col items-center justify-center h-full min-h-80 text-center">
        <div class="flex items-center justify-center w-14 h-14 rounded-2xl mb-5 text-[--color-brand]"
             style="background-color: var(--color-brand-muted);">
          <i data-lucide="wand-2" class="w-7 h-7"></i>
        </div>
        <h3 class="text-base font-semibold text-[--color-text-base] mb-2">Ready to generate</h3>
        <p class="text-sm text-[--color-text-muted] max-w-xs">Choose a base colour, mood, and harmony rule on the left, then hit <strong class="text-[--color-text-base]">Generate Palette</strong>.</p>
      </div>
    <% end %>

  </div>
</div>
