<% content_for :title, "Palette Library — UISchemes" %>

<div class="px-8 py-10 max-w-5xl mx-auto">

  <%# Header %>
  <div class="mb-8">
    <h1 class="text-2xl font-bold tracking-tight text-[--color-text-base] mb-1">Palette Library</h1>
    <p class="text-sm text-[--color-text-muted]">Browse curated CSS colour palettes. Filter by tag to find the right style.</p>
  </div>

  <%# Tag filter pills %>
  <div class="flex items-center gap-2 flex-wrap mb-8">
    <%= link_to palettes_path,
          class: "inline-flex items-center px-3 py-1.5 rounded-full text-xs font-medium transition-colors duration-150 #{@active_tag.nil? ? 'bg-[--color-brand] text-white' : 'border border-[--color-border] text-[--color-text-muted] hover:text-[--color-text-base] hover:border-[--color-brand-muted]'}" do %>
      All
    <% end %>

    <% @tags.each do |tag| %>
      <% is_active = @active_tag == tag.slug %>
      <%= link_to palettes_path(tag: tag.slug),
            class: "inline-flex items-center px-3 py-1.5 rounded-full text-xs font-medium transition-colors duration-150 #{is_active ? 'bg-[--color-brand] text-white' : 'border border-[--color-border] text-[--color-text-muted] hover:text-[--color-text-base] hover:border-[--color-brand-muted]'}" do %>
        <%= tag.name %>
      <% end %>
    <% end %>
  </div>

  <% if @palettes.any? %>
    <%# Palette card grid %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% @palettes.each do |palette| %>
        <div class="flex flex-col rounded-xl border border-[--color-border] bg-[--color-surface] overflow-hidden hover:border-[--color-brand-muted] transition-colors duration-200">

          <%# Colour swatch strip %>
          <div class="flex h-16">
            <% palette.colour_roles.each do |role, hex| %>
              <div class="flex-1 h-full" style="background-color: <%= hex %>;" title="<%= role %>: <%= hex %>"></div>
            <% end %>
          </div>

          <%# Card body %>
          <div class="flex flex-col gap-3 p-4">
            <div>
              <h3 class="font-semibold text-[--color-text-base] text-sm mb-0.5"><%= palette.name %></h3>
              <% if palette.description.present? %>
                <p class="text-xs text-[--color-text-muted] leading-relaxed line-clamp-2"><%= palette.description %></p>
              <% end %>
            </div>

            <%# Colour role pills %>
            <div class="grid grid-cols-3 gap-1.5">
              <% palette.colour_roles.each do |role, hex| %>
                <div class="flex items-center gap-1.5 group">
                  <div class="w-3 h-3 rounded-sm shrink-0 ring-1 ring-black/20" style="background-color: <%= hex %>;"></div>
                  <div class="min-w-0">
                    <p class="text-[10px] text-[--color-text-faint] capitalize leading-none mb-0.5"><%= role %></p>
                    <p class="text-[10px] font-mono text-[--color-text-muted] truncate"><%= hex %></p>
                  </div>
                </div>
              <% end %>
            </div>

            <%# Tags %>
            <% if palette.tags.any? %>
              <div class="flex items-center gap-1.5 flex-wrap pt-1 border-t border-[--color-border-subtle]">
                <% palette.tags.each do |tag| %>
                  <%= link_to palettes_path(tag: tag.slug),
                        class: "inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium border border-[--color-border] text-[--color-text-faint] hover:text-[--color-brand] hover:border-[--color-brand-muted] transition-colors duration-150" do %>
                    <%= tag.name %>
                  <% end %>
                <% end %>
              </div>
            <% end %>

            <%# Export panel %>
            <div data-controller="disclosure" class="pt-1 border-t border-[--color-border-subtle]">
              <button
                data-action="click->disclosure#toggle"
                class="flex items-center gap-1.5 text-[11px] font-medium text-[--color-text-faint] hover:text-[--color-brand] transition-colors duration-150 w-full">
                <i data-lucide="download" class="w-3 h-3"></i>
                Export
              </button>

              <div data-disclosure-target="content" hidden class="flex items-center gap-1.5 mt-2 flex-wrap">
                <% [
                  ["CSS",      palette.to_css],
                  ["Tailwind", palette.to_tailwind_config],
                  ["JS",       palette.to_js_module]
                ].each do |label, text| %>
                  <button
                    data-controller="clipboard"
                    data-clipboard-text-value="<%= text %>"
                    data-action="click->clipboard#copy"
                    class="inline-flex items-center gap-1 px-2.5 py-1 rounded-md border border-[--color-border] bg-[--color-canvas] text-[10px] font-medium text-[--color-text-muted] hover:text-[--color-brand] hover:border-[--color-brand-muted] transition-colors duration-150">
                    <i data-lucide="copy" class="w-3 h-3"></i>
                    <span data-clipboard-target="label">Copy <%= label %></span>
                  </button>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>

  <% else %>
    <%# Empty / no-match state %>
    <div class="flex flex-col items-center justify-center py-24 rounded-xl border border-dashed border-[--color-border] text-center">
      <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-[--color-surface-raised] mb-4 text-[--color-text-faint]">
        <i data-lucide="library" class="w-6 h-6"></i>
      </div>
      <% if @active_tag %>
        <h3 class="text-sm font-semibold text-[--color-text-base] mb-1">No palettes match this filter</h3>
        <p class="text-sm text-[--color-text-muted] max-w-xs mb-4">Try a different tag or browse all palettes.</p>
        <%= link_to "Clear filter", palettes_path, class: "text-xs text-[--color-brand] hover:underline" %>
      <% else %>
        <h3 class="text-sm font-semibold text-[--color-text-base] mb-1">No palettes yet</h3>
        <p class="text-sm text-[--color-text-muted] max-w-xs">The library is empty. Palettes will appear here once they've been added.</p>
      <% end %>
    </div>
  <% end %>

</div>
